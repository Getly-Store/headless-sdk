# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot)
BOT_TOKEN=

# Getly API key with the `checkout:create` scope.
# Create one at https://www.getly.store/dashboard/developer/keys
# NEVER commit this file with a real key. NEVER pass the key as a CLI argument.
GETLY_API_KEY=

# Your store slug — the part after /store/ in your storefront URL,
# e.g. "neon-ui" for https://www.getly.store/store/neon-ui
STORE_SLUG=
